# Copy to .env.local and fill in to switch from sample data to the live Airship API.
# With no token set, the app serves realistic sample data (badge shows "Sample data").

# Access token generated in the Airship dashboard. Presence of this flips the app to live.
AIRSHIP_API_TOKEN=

# --- Optional overrides (only set if the live payload differs from defaults) ---

# Base URL. Default: https://api.airship.co.uk/v1
# AIRSHIP_API_BASE_URL=https://api.airship.co.uk/v1

# Auth header name + prefix. Default sends:  Authorization: Bearer <token>
# AIRSHIP_AUTH_HEADER=Authorization
# AIRSHIP_AUTH_PREFIX="Bearer "

# Secret used to sign per-segment share links (/segment/[id]?t=...). Set a long
# random value in production; a dev fallback is used if unset (not secret).
# SCV_SHARE_SECRET=

